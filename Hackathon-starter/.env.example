# Application Settings
APP_NAME=Zava AI Portal
ENVIRONMENT=development
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/zava

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8000

# Azure OpenAI Configuration (calls directly - no MCP server needed)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# GitHub Integration (optional - for code analysis features)
GH_PAT=your-github-personal-access-token
GH_REPOSITORY=owner/repo-name

# Security
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
