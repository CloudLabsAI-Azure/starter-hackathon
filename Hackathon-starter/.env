# Application Settings
APP_NAME=Zava AI Portal
ENVIRONMENT=development
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hackathon_db

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080,http://127.0.0.1:3000

# MCP Configuration
MCP_SERVER_URL=http://localhost:8000
MCP_ENABLED=true

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=<azure-openai-endpoint>
# AZURE_OPENAI_API_KEY=<azure-openai-api-key>
# AZURE_OPENAI_DEPLOYMENT_NAME=<azure-openai-deployment-name>
# AZURE_OPENAI_API_VERSION=<azure-openai-api-version>

# NVIDIA Configuration
NVIDIA_NIM_ENDPOINT=<nvidia-nim-endpoint>
NVIDIA_NIM_API_KEY=<nvidia-nim-api-key>
NVIDIA_NIM_MODEL=<nvidia-nim-model>
NVIDIA_NIM_BASE_URL=<https://aiproject-XXXXXX-xflgp.xxxxx.inference.ml.azure.com/v1>(Add the baseurl only till v1)

# Azure AI search (for knowledge tools)
AZURE_AI_SEARCH_ENDPOINT=<Azure-AI-search-endpoint>
AZURE_SEARCH_API_KEY=<Azure-AI-search-api-key>
AZURE_AI_SEARCH_API_VERSION=<Azure-AI-Search-Version>
SEARCH_AUTHENTICATION_METHOD=api-search-key

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# GitHub Configuration
GITHUB_TOKEN=<github-token>
GITHUB_REPO=<github-repo>
GITHUB_BRANCH=main
