# Application Settings
APP_NAME=Zava AI Portal
ENVIRONMENT=development
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hackathon_db

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080,http://127.0.0.1:3000

# MCP Configuration
MCP_SERVER_URL=http://localhost:8000
MCP_ENABLED=true

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=<endpoint>
AZURE_OPENAI_API_KEY=<your-openai-key>
AZURE_OPENAI_DEPLOYMENT_NAME=<you-deployment-model>
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# GitHub Configuration
GITHUB_TOKEN=<github-token>
GITHUB_REPO=<odl-repo>